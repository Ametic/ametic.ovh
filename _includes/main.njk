
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{ title or "ametic.ovh" }}</title>
    <link rel="icon" href="/assets/img/favicon.png" />
    <link rel="stylesheet" href="/assets/css/styles.css" />
  </head>
  <body>
    {% if description %}
    <section class="hero">
      <div class="container">
        <p class="subtitle">{{ description }}</p>
      </div>
    </section>
    {% endif %}
    <main class="container">
      {% if page.url != "/" %}
      <div class="dir-nav">
        <div class="dir-current">current dir: /ametic/ametic.ovh/home</div>
        <div class="dir-links">
          <a href="/">/home</a>
          <a href="/projects/">/projects</a>
          <a href="/blog/">/blog</a>
          <a href="/setup/">/setup</a>
        </div>
      </div>
      {% endif %}
      {{ content | safe }}
    </main>
    {% include "footer.njk" %}
    <script src="/assets/js/ascii-banner.js" defer></script>
  </body>
</html>
